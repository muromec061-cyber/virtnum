# Aisunio Bot Environment Variables

# Required
TELEGRAM_BOT_TOKEN=your_bot_token

# GitHub Models API (free, unlimited)
GITHUB_ACCESS_TOKEN=your_github_pat

# Tinkoff Payment (optional — for real payments)
# Get these from https://securepay.tinkoff.ru/
TINKOFF_TERMINAL_KEY=your_terminal_key
TINKOFF_PASSWORD=your_password

# Port (auto-set by Render/Docker)
PORT=3000

# Node
NODE_ENV=production
