# ─── Database ──────────────────────────────────────
POSTGRES_DB=virtnum
POSTGRES_USER=virtnum
POSTGRES_PASSWORD=your_strong_password_here

DATABASE_URL=postgresql://virtnum:your_strong_password_here@localhost:5432/virtnum

# ─── JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_64chars_minimum_random_string
JWT_REFRESH_SECRET=change_me_refresh_64chars_minimum_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── App ───────────────────────────────────────────
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ─── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# ─── CORS ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── SMS Gateway ───────────────────────────────────
# API key for incoming SMS webhook (set any strong random string)
SMS_GATEWAY_API_KEY=your_sms_gateway_secret_key
